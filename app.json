{
  "expo": {
    "name": "Nanmii Asset",
    "slug": "nanmii-mobile-app",
    "version": "1.0.0",
    "sdkVersion": "50.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "entryPoint": "./index.js",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "gradle": {
              "sourceCompatibility": "11",
              "targetCompatibility": "11"
            }
          }
        }
      ]
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.nanmii.asset"
    },
    "android": {
      "package": "com.nanmii.asset",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "b5e95b60-d027-4603-860d-c92e7c307ea9"
      }
    }
  }
}
