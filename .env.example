# 🔐 Variables d'environnement - Exemple
# Copiez ce fichier en `.env.local` et remplissez vos valeurs

# ⚠️ NE COMMITTEZ PAS CE FICHIER AVEC LES VRAIES VALEURS!
# Utilisez GitHub Secrets pour les CI/CD

# Expo Token (pour builds EAS locales)
# Obtenez-le via: https://expo.dev/settings/applications
EXPO_TOKEN=

# Project Configuration
EXPO_PROJECT_ID=b5e95b60-d027-4603-860d-c92e7c307ea9
EAS_PROJECT_NAME=nanmii-mobile-app
EXPO_OWNER=maxy123

# Build Configuration
EAS_BUILD_PROFILE=preview
EAS_BUILD_PLATFORM=android

# Optional: Slack Notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=builds

# Optional: Firebase
FIREBASE_PROJECT_ID=
FIREBASE_APP_DISTRIBUTION_TOKEN=

# Optional: Google Play
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
